{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "ignoreDeprecations": "5.0",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/components/*": ["frontend/components/*"],
      "@/lib/utils": ["frontend/lib/utils"],
      "@/lib/audit-engine": ["backend/lib/audit-engine"],
      "@/lib/audit-engine/*": ["backend/lib/audit-engine/*"],
      "@/lib/validators": ["backend/lib/validators"],
      "@/lib/supabase": ["backend/lib/supabase"],
      "@/types": ["shared/types"],
      "@/types/*": ["shared/types/*"],
      "@/backend/*": ["backend/*"],
      "@/frontend/*": ["frontend/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
