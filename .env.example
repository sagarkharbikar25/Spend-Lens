# Copy to .env.local and fill in values (see database/README.md for Supabase)

# Supabase
# Use the project base URL only. Do not include /rest/v1/.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Meta AI (Llama) — free tier summary on Day 2+
META_API_KEY=your-meta-api-key
# META_MODEL=Llama-3.3-70B-Instruct

# Optional: Anthropic (assignment default LLM)
# ANTHROPIC_API_KEY=sk-ant-your-key

# Resend (Day 3 — lead confirmation email)
RESEND_API_KEY=re_your-key
# RESEND_FROM_EMAIL=SpendLens <onboarding@resend.dev>

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
